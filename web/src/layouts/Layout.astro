---
import "@/styles/globals.css";
import { CommandPalette } from "@/components/layout/CommandPalette";
import { JobsDrawer } from "@/components/layout/JobsDrawer";

interface Props {
  title: string;
  active?: string;
}

const { title, active } = Astro.props;

const navItems = [
  { label: "Dashboard", href: "/", id: "dashboard", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>` },
  { label: "Stacks", href: "/stacks", id: "stacks", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>` },
  { label: "Containers", href: "/containers", id: "containers", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>` },
  { label: "Networks", href: "/networks", id: "networks", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><path d="M12 8v4"/><path d="m8 16-3-3"/><path d="m16 16 3-3"/></svg>` },
  { label: "Volumes", href: "/volumes", id: "volumes", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 5c0-1.1-3.6-2-8-2s-8 .9-8 2"/><path d="M3 5v14c0 1.1 3.6 2 8 2s8-.9 8-2V5"/><path d="M3 12c0 1.1 3.6 2 8 2s8-.9 8-2"/></svg>` },
  { label: "Images", href: "/images", id: "images", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="m7 10 5 5 5-5"/></svg>` },
  { label: "Pipelines", href: "/pipelines", id: "pipelines", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>` },
  { label: "Settings", href: "/settings", id: "settings", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>` },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Mobile sidebar overlay -->
      <div id="mobile-overlay" class="fixed inset-0 z-40 bg-black/50 hidden md:hidden" onclick="document.getElementById('sidebar').classList.add('hidden');document.getElementById('mobile-overlay').classList.add('hidden');"></div>

      <!-- Sidebar -->
      <aside id="sidebar" class="hidden md:flex w-60 flex-col border-r border-border bg-cp-950 fixed md:static inset-y-0 left-0 z-50">
        <!-- Logo -->
        <div class="flex h-14 items-center px-4 border-b border-border">
          <span class="text-sm font-bold uppercase tracking-widest glow-purple text-cp-purple">
            Composer
          </span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 space-y-1 p-3">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
                active === item.id
                  ? "bg-cp-purple/10 text-cp-purple"
                  : "text-muted-foreground hover:bg-accent hover:text-foreground",
              ]}
              data-testid={`nav-${item.id}`}
            >
              <Fragment set:html={item.icon} />
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Footer -->
        <div class="border-t border-border p-3">
          <div class="text-xs text-muted-foreground font-data" id="composer-version">Composer</div>
          <script is:inline src="/version-init.js"></script>
        </div>
      </aside>

      <!-- Main area -->
      <div class="flex flex-1 flex-col overflow-hidden">
        <!-- Header -->
        <header class="flex h-14 items-center gap-4 border-b border-border bg-cp-950/50 px-6">
          <button
            id="mobile-menu-btn"
            class="md:hidden p-1 rounded hover:bg-accent"
            aria-label="Open navigation"
            onclick="document.getElementById('sidebar').classList.remove('hidden');document.getElementById('mobile-overlay').classList.remove('hidden');"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <h1 class="text-lg font-semibold" data-testid="page-title">{title}</h1>
          <div class="ml-auto flex items-center gap-3">
            <JobsDrawer client:load />
            <div class="flex items-center gap-2" id="health-indicator">
              <span class="relative flex h-2 w-2">
                <span class="relative inline-flex rounded-full h-2 w-2 bg-cp-600"></span>
              </span>
              <span class="text-xs text-muted-foreground">Checking...</span>
            </div>
            <button
              id="logout-btn"
              class="text-xs text-muted-foreground hover:text-cp-red transition-colors px-2 py-1 rounded border border-transparent hover:border-cp-red/30"
              title="Sign out"
            >
              Sign out
            </button>
            <script is:inline src="/layout-init.js"></script>
          </div>
        </header>

        <!-- Content -->
        <main class="flex-1 overflow-y-auto p-6">
          <slot />
        </main>
      </div>
    </div>
    <!-- Command Palette (Cmd+K) -->
    <CommandPalette client:load />
  </body>
</html>
