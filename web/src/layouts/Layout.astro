---
import "@/styles/globals.css";

interface Props {
  title: string;
  active?: string;
}

const { title, active } = Astro.props;

const navItems = [
  { label: "Dashboard", href: "/", id: "dashboard", icon: "grid" },
  { label: "Stacks", href: "/stacks", id: "stacks", icon: "layers" },
  { label: "Pipelines", href: "/pipelines", id: "pipelines", icon: "workflow" },
  { label: "Settings", href: "/settings", id: "settings", icon: "settings" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside class="hidden md:flex w-60 flex-col border-r border-border bg-cp-950">
        <!-- Logo -->
        <div class="flex h-14 items-center px-4 border-b border-border">
          <span class="text-sm font-bold uppercase tracking-widest glow-purple text-cp-purple">
            Composer
          </span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 space-y-1 p-3">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
                active === item.id
                  ? "bg-cp-purple/10 text-cp-purple"
                  : "text-muted-foreground hover:bg-accent hover:text-foreground",
              ]}
              data-testid={`nav-${item.id}`}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Footer -->
        <div class="border-t border-border p-3">
          <div class="text-xs text-muted-foreground font-data">Composer v0.1.0</div>
        </div>
      </aside>

      <!-- Main area -->
      <div class="flex flex-1 flex-col overflow-hidden">
        <!-- Header -->
        <header class="flex h-14 items-center gap-4 border-b border-border bg-cp-950/50 px-6">
          <h1 class="text-lg font-semibold" data-testid="page-title">{title}</h1>
          <div class="ml-auto flex items-center gap-2">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cp-green opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-cp-green"></span>
              </span>
              <span class="text-xs text-muted-foreground">Healthy</span>
            </div>
          </div>
        </header>

        <!-- Content -->
        <main class="flex-1 overflow-y-auto p-6">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
