---
import Layout from "@/layouts/Layout.astro";
import { StacksRouter } from "@/components/stack/StacksRouter";
---

<Layout title="Stacks" active="stacks">
  <!-- client:only because BrowserRouter touches window during init,
       which Astro's SSR step can't supply. -->
  <StacksRouter client:only="react" />
</Layout>
