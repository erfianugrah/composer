---
import Layout from "@/layouts/Layout.astro";
import { UserManagement } from "@/components/layout/UserManagement";
import { ApiKeyManagement } from "@/components/layout/ApiKeyManagement";
import { WebhookSettings } from "@/components/layout/WebhookSettings";
import { ImportStacks } from "@/components/stack/ImportStacks";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
---

<Layout title="Settings" active="settings">
  <div class="space-y-6">
    <UserManagement client:load />
    <ApiKeyManagement client:load />
    <WebhookSettings client:load />
    <ImportStacks client:load />

    <Card>
      <CardHeader>
        <CardTitle className="text-sm">System</CardTitle>
      </CardHeader>
      <CardContent>
        <p class="text-sm text-muted-foreground font-data" id="settings-version">Loading...</p>
        <script is:inline>
          fetch("/api/v1/system/version",{credentials:"include",headers:{"X-Requested-With":"XMLHttpRequest"}})
            .then(r=>r.json()).then(d=>{
              const el=document.getElementById("settings-version");
              if(el)el.textContent=`Composer v${d.version} | Go ${d.go_version} | ${d.os}/${d.arch} | Uptime: ${d.uptime}`;
            }).catch(()=>{
              const el=document.getElementById("settings-version");
              if(el)el.textContent="Could not fetch system info";
            });
        </script>
      </CardContent>
    </Card>
  </div>
</Layout>
